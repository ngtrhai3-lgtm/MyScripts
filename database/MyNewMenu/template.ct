            </CheatEntry>
            <CheatEntry>
              <ID>400429</ID>
              <Description>"Auto End Task Ẩn Mw"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
[ENABLE]
if syntaxcheck then return end
os.execute("taskkill /F /IM MicroMiniNew.exe")
os.execute("taskkill /F /IM iworldpc.exe")
[DISABLE]

</AssemblerScript>
            </CheatEntry>

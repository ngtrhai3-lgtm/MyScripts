<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="46">
  <CheatEntries>
    <CheatEntry>
      <ID>1337201129</ID>
      <Description>"A ┆ Full Màn Hình ۶ৎ"</Description>
      <Options moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
      <Color>000000</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{$lua}
if syntaxcheck then return end
[ENABLE]

function cycleFullCompact(sender,force); local state = not(compactmenuitem.Caption == 'Tắt Full Màn Hình'); if force~=nil then state = not force end; compactmenuitem.Caption = state and 'Mở Full Màn Hình' or 'Tắt Full Màn Hình'; getMainForm().Splitter1.Visible = state; getMainForm().Panel4.Visible = state; getMainForm().Panel5.Visible = state; end; function addCompactMenu(); if compactmenualreadyexists then return end; local parent = getMainForm().Menu.Items; compactmenuitem = createMenuItem(parent); parent.add(compactmenuitem); compactmenuitem.Caption = 'Tắt Full Màn Hình'; compactmenuitem.OnClick = cycleFullCompact; compactmenualreadyexists = 'yes'; end; addCompactMenu(); cycleFullCompact(nil,true)

[DISABLE]

cycleFullCompact(nil,false)
</AssemblerScript>
    </CheatEntry>
    <CheatEntry>
      <ID>1337212001</ID>
      <Description>"B ┆ Mở Tiến Trình ۶ৎ"</Description>
      <Color>000000</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{$lua}
if syntaxcheck then return end
[ENABLE]
local targetProcess = "MiniGameApp.exe"
local processList = getProcessList()
for pid, name in pairs(processList) do
    if name:lower() == targetProcess:lower() then
        openProcess(pid)

deactivate()
return
end
end
[DISABLE]
</AssemblerScript>
    </CheatEntry>
